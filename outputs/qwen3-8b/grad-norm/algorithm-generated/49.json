y\n    }\n\n    for gift, recipient in potential_matches.items():\n        matched_gifts.append({\"gift\": gift, \"recipient\": recipient})\n\n    return matched_gifts\n\nprofiles = {\n    'Harry': ['Fishing', 'Camping', 'Wine'],\n    'Rebecca': ['Cars', 'Dogs', 'Chocolate'],\n    'Georgette': ['Yoga', 'Cooking', 'Green Energy'],\n    'Micah': ['Knitting', 'Rainy Weather', 'Books'],\n    'Perry': ['Old Movies', 'Rats', 'Journaling'],\n    'Tyson': ['Historical Fiction Novels', 'Biking', 'Parakeets'],\n    'Lucy': ['Coffee', 'Physics', 'Board Games'],\n    'Jun': ['Woodworking', 'Barbecue', 'JavaScript'],\n    'Sara': ['Tabletop RPGs', 'Spas', 'Music'],\n    'Miguel': ['Astronomy', 'Decorative Washi Tape', 'Ketchup'],\n    'Fred': ['Chemistry', 'Perl', 'Cats'],\n    'Alex': ['Surfing', 'Audrey Hepburn', 'Manga']\n}\n\ngifts = [\n    \"Galileo Galilei biography\",\n    \"Fishing reel\",\n    \"Raku programming guide\",\n    \"Chisel set\",\n    \"Custom dice\",\n    \"War and Peace American film copy\",\n    \"Yarn\",\n    \"One Piece graphic novel\",\n    \"War and Peace novel\",\n    \"Starbucks gift card\",\n    \"Foam exercise mat\"\n]\n\nmatched_gifts = match_gifts_to_profiles(profiles, gifts)\n\n# Check who didn't give a gift\nall_employees = set(profiles.keys())\ngivers = set([gift['recipient'] for gift in matched_gifts])\nnon_giver = all_employees - givers\n\nprint(\"Matched Gifts:\", matched_gifts)\nprint(\"Non-giver:\", non_giver)\n```\n\nComputer_terminal, please execute this code to match the gifts and identify who did not give a gift."
